---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Solution from '../components/Solution.astro';
import HowItWorks from '../components/HowItWorks.astro';
import CaseStudy from '../components/CaseStudy.astro';
import Pricing from '../components/Pricing.astro';
import About from '../components/About.astro';
import FAQ from '../components/FAQ.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
import { pricingTiers } from '../data/pricing';
import { faqItems } from '../data/faq';
import {
  organizationSchema,
  personSchema,
  serviceSchema,
  faqPageSchema,
} from '../data/schema';

const title = 'Petre Laskov | AI Agent Environments for Business';
const description =
  'Custom AI agent environments that integrate into your workflows. Built with a proven methodology. Discovery call to working system in days, not months.';

const schemas = [
  organizationSchema(),
  personSchema(),
  serviceSchema(pricingTiers),
  faqPageSchema(faqItems),
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>
  <Header />
  <main>
    <Hero />
    <Problem />
    <Solution />
    <HowItWorks />
    <CaseStudy />
    <Pricing />
    <About />
    <FAQ />
    <FinalCta />
  </main>
  <Footer />
</BaseLayout>
