---
import { caseStudy } from '../data/copy';
---

<section id="case-study" class="px-6 py-16 sm:py-24">
  <div class="mx-auto max-w-[--container-lg]">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary-600">
      {caseStudy.eyebrow}
    </p>
    <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
      {caseStudy.headline}
    </h2>
    <p class="mt-1 text-lg text-gray-500">{caseStudy.subtitle}</p>

    <div class="mt-8 rounded-xl border border-gray-200 bg-gray-50 p-8">
      <blockquote class="text-lg italic text-gray-700">
        &ldquo;{caseStudy.quote}&rdquo;
      </blockquote>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-3">
      {caseStudy.results.map((result) => (
        <div class="text-center">
          <p class="text-3xl font-bold text-primary-600">{result.value}</p>
          <p class="mt-1 text-sm text-gray-600">{result.metric}</p>
        </div>
      ))}
    </div>

    <p class="mt-10 max-w-3xl text-lg text-gray-600">
      {caseStudy.description}
    </p>
  </div>
</section>
