---
import { pricingTiers } from '../data/pricing';
---

<section id="pricing" class="bg-gray-50 px-6 py-16 sm:py-24">
  <div class="mx-auto max-w-[--container-lg]">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary-600">
      Pricing
    </p>
    <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
      Transparent pricing, no surprises
    </h2>
    <p class="mt-4 max-w-2xl text-lg text-gray-600">
      Every tier includes the methodology &mdash; you learn how it works as we build it together.
    </p>

    <div class="mt-12 grid gap-8 lg:grid-cols-3">
      {pricingTiers.map((tier) => (
        <div
          class:list={[
            'flex flex-col rounded-xl border p-8',
            tier.highlighted
              ? 'border-primary-500 bg-white shadow-lg ring-1 ring-primary-500'
              : 'border-gray-200 bg-white',
          ]}
        >
          {tier.highlighted && (
            <span class="-mt-12 mb-4 self-start rounded-full bg-primary-600 px-3 py-1 text-xs font-semibold text-white">
              Most popular
            </span>
          )}
          <h3 class="text-xl font-bold text-gray-900">{tier.name}</h3>
          <p class="mt-2 text-sm text-gray-600">{tier.description}</p>
          <p class="mt-6">
            <span class="text-4xl font-bold text-gray-900">&euro;{tier.price}</span>
          </p>
          <ul class="mt-8 flex-1 space-y-3">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <svg
                  class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary-600"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2.5"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
          <a
            href="#contact"
            class:list={[
              'mt-8 block rounded-lg px-6 py-3 text-center text-base font-semibold transition-colors',
              tier.highlighted
                ? 'bg-accent-500 text-white shadow-sm hover:bg-accent-600'
                : 'border border-gray-300 text-gray-700 hover:bg-gray-50',
            ]}
          >
            {tier.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
