---
import { hero } from '../data/copy';
---

<section class="px-6 pb-16 pt-20 sm:pb-24 sm:pt-28">
  <div class="mx-auto max-w-[--container-lg] text-center">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl">
      {hero.headline}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 sm:text-xl">
      {hero.subheadline}
    </p>
    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href={hero.primaryCta.href}
        class="rounded-lg bg-accent-700 px-6 py-3 text-base font-semibold text-white shadow-sm transition-colors hover:bg-accent-800"
      >
        {hero.primaryCta.label}
      </a>
      <a
        href={hero.secondaryCta.href}
        class="rounded-lg border border-gray-300 px-6 py-3 text-base font-semibold text-gray-700 transition-colors hover:bg-gray-50"
      >
        {hero.secondaryCta.label}
      </a>
    </div>
    <p class="mt-8 text-sm text-gray-500">
      {hero.proof}
    </p>
  </div>
</section>
