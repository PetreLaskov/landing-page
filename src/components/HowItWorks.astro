---
import { howItWorks } from '../data/copy';
---

<section id="how-it-works" class="bg-gray-50 px-6 py-16 sm:py-24">
  <div class="mx-auto max-w-[--container-lg]">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary-800">
      {howItWorks.eyebrow}
    </p>
    <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
      {howItWorks.headline}
    </h2>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {howItWorks.steps.map((step) => (
        <div class="relative">
          <span class="text-4xl font-bold text-primary-500">{step.number}</span>
          <h3 class="mt-2 text-lg font-semibold text-gray-900">{step.title}</h3>
          <p class="mt-2 text-gray-600">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
