---
import { faqItems } from '../data/faq';
---

<section id="faq" class="bg-gray-50 px-6 py-16 sm:py-24">
  <div class="mx-auto max-w-[--container-lg]">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary-600">
      FAQ
    </p>
    <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
      Common questions
    </h2>

    <div class="mt-10 max-w-3xl divide-y divide-gray-200">
      {faqItems.map((item) => (
        <details class="group py-5">
          <summary class="flex cursor-pointer items-center justify-between text-lg font-semibold text-gray-900">
            {item.question}
            <svg
              class="h-5 w-5 flex-shrink-0 text-gray-400 transition-transform group-open:rotate-45"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </summary>
          <p class="mt-3 text-gray-600">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
